        }
        //şimdi maskeyi hareket ettirerek recursive
        //b maske

        static int bitsayısı(uint a,uint b)
        {
            if (b == 0) return 0;
            
           // return ((a & b)!=0?1:0) //burada a ve b andlendiğinde sonuç
                                    //0'dan farklıysa 1 değilse 0 gönder 
             //   + bitsayısı(a,b<< 1);
            //bunu yazamazsak 

            if ((a & b)!=0)
                 return 1 + bitsayısı(a, b << 1);
            else return bitsayısı(a, b << 1);
        }
        static uint onlu_sayı_sistemi(uint a,uint b,uint çarpan)
        {
            //maskeyi kullanmadanki hali
            //if (a == 0) return 0;
            //return çarpan * (a & 1) + onlu_sayı_sistemi(a, çarpan*2);

            //maskeyi de kullanırsak
            if (b == 0) return 0;
            return çarpan * (uint)((a & b)!=0?1:0 )
                            //aslında burası if kısmı
                + onlu_sayı_sistemi(a, b>>1 ,çarpan * 2);
        }
        static uint kıyaslama(uint a,uint b)
        {
            if (a == 0 && b==0) return 1;
            if ((a & 1) == (b & 1)) return kıyaslama(a >> 1, b >> 1);
            else return 0;
            
        }

        static int ascıı(string s, int b, int leng)
        {
            if (leng >= s.Length) return 0;

            return b * (s[leng] - '0') * ascıı(s, b * 10, leng + 1);
