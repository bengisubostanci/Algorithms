        //şimdi recursive ile yapacağız bunları
        static int bitsayısı(uint a)
        {
            if (a == 0) return 0;
            //if ((a & 1) == 1) 
            //     return 1 + bitsayısı(a >>1);
            //else return 0 + bitsayısı(a >>1);

            //ya da 
