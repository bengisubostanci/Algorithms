        class btree
        {
            public int data;
            public int ch;
            public string huffman;
            public btree left;
            public btree right;

        }
        static void huffmantreeolustur(btree[] bt)
        {
            ///sort edildiğinde en küçük iki elemanı 0. ve 1. indexte bulunur
            if (bt[1] == null) return;// bütün elemanlar 1.elemanda toplanmışsa
                                      // ve artık ikinci değerimizde null ise artık recursive
                                      // yapıyı kırmış oluruz

            btree b = new btree(); ///örneğin c ve d 'yi birleştirirken c ve d'nin üstüne cd bloğu oluşturmak gibi
                                   ///       cd
                                   ///     c    d
            b.left = bt[0]; //bu oluşturduğumuz bloğun 1. elemanı sola baksın
            b.right = bt[1]; //2. elemanı sağa baksın
            b.data = bt[0].data + bt[1].data;//frekansları topladık
            ///iki değeri birleştirdikten sonra tekine atayıp diğerini de null yaptıktan sonra
            ///tekrar sort işlemini gerçekleştiriyoruz
            ///sorttan sonra da null dğeri en sona gelir
            bt[0] = b; //bu topladığımız bloğu 0. indexe taşıdık ve 
            bt[1] = null; //1. indexi null'a çevirdik , dizilerden silme olmadığı için
            Array.Sort(bt, (object x, object y) =>
            {
                int a = 0;
                if (x == null && y == null) return 0; //nulları en sona atmak için
                if (x == null) return 1; if (y == null) return -1;

                if (((btree)x).data < ((btree)y).data) a = -1;
                if (((btree)x).data > ((btree)y).data) a = 1;
                return a;

            });
            huffmantreeolustur(bt);
        }
        static void huffmanstryaz(btree bt, string yon)
        {
            if (bt == null) return;
            ///sağa1, sola0 yazma işelemini gerçekleştireceğiz

            if (bt.left == null) bt.huffman = yon; ///ilk return çalışmadı bu yüzden sağa
                                                   ///ya da sola gidecek demek
            huffmanstryaz(bt.left, yon + "0"); ///burada sola gideceği için 0 yazdık     
            
            if (bt.right == null) bt.huffman = yon;
            huffmanstryaz(bt.right, yon + "1");
        }
        static string huffmanfind(btree bt, int ch)
        {
            if (bt == null) return "";
            if (bt.ch == ch) return bt.huffman;
            return huffmanfind(bt.left, ch) + huffmanfind(bt.right, ch);

        }
        static void huffmantreeyaz(btree bt)
        {
            //şimdi ekrana yazdırmak var
            if (bt == null) return;
            if(bt.left==null)
                Console.WriteLine("{0} {1}", (char)bt.ch,bt.huffman);
            huffmantreeyaz(bt.left);
            huffmantreeyaz(bt.right);
            
